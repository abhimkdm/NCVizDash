<Window x:Class="NCVizDash.TaskPane.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:NCVizDash.TaskPane.Behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:NCVizDash.TaskPane.ViewModels"
        xmlns:conv="clr-namespace:NCVizDash.TaskPane.Converters"
        xmlns:views="clr-namespace:NCVizDash.TaskPane.Views"
        mc:Ignorable="d"
        Title="NC VizDash"
        Height="900" Width="1400"
        MinHeight="600" MinWidth="900"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignBackground}"
        FontFamily="{md:MaterialDesignFont}"
        d:DataContext="{d:DesignInstance vm:ShellViewModel}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <md:BundledTheme BaseTheme="Light"
                                 PrimaryColor="DeepPurple"
                                 SecondaryColor="Teal" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <conv:GridUnitConverter x:Key="GridUnitConverter" />
            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
            <conv:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
            <conv:FilterValuesToStringConverter x:Key="FilterValuesToStringConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top bar -->
            <RowDefinition Height="48" />
            <!-- Main content -->
            <RowDefinition Height="*" />
            <!-- Status bar -->
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- ── Top Bar ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueMidBrush}"
                Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" behaviors:SpacingBehavior.Spacing="10">
                    <md:PackIcon Kind="ChartAreaspline"
                                 Width="28" Height="28"
                                 Foreground="White"
                                 VerticalAlignment="Center" />
                    <TextBlock Text="NC VizDash"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Loading indicator -->
                <ProgressBar Grid.Column="1"
                             IsIndeterminate="{Binding IsLoading}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"
                             VerticalAlignment="Bottom"
                             Margin="24,0" />

                <!-- Theme toggle -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" behaviors:SpacingBehavior.Spacing="8">
                    <TextBlock Text="Dark"
                               Foreground="White"
                               VerticalAlignment="Center"
                               FontSize="12" />
                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  ToolTip="Toggle Light / Dark theme"
                                  Command="{Binding ApplyThemeCommand}"
                                  CommandParameter="Dark" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Three-Panel Main Content ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left: Explorer -->
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400" />
                <ColumnDefinition Width="4" />
                <!-- Centre: Canvas -->
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
                <!-- Right: Visual Library -->
                <ColumnDefinition Width="220" MinWidth="190" MaxWidth="340" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: Workbook Explorer -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,1,0">
                <ContentControl Content="{Binding ExplorerPanel}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:ExplorerPanelView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource MaterialDesignDivider}" />

            <!-- CENTRE: Dashboard Canvas -->
            <Border Grid.Column="2"
                    Background="{DynamicResource MaterialDesignBackground}">
                <ContentControl Content="{Binding CanvasPanel}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:CanvasPanelView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource MaterialDesignDivider}" />

            <!-- RIGHT: Visual Library -->
            <Border Grid.Column="4"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1,0,0,0">
                <ContentControl Content="{Binding VisualLibrary}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:VisualLibraryView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>
        </Grid>

        <!-- ── Status Bar ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
        </Border>
    </Grid>
</Window>
