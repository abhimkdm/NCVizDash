<UserControl x:Class="NCVizDash.TaskPane.Views.CanvasPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:NCVizDash.TaskPane.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:NCVizDash.TaskPane.ViewModels"
             xmlns:ctrl="clr-namespace:NCVizDash.TaskPane.Controls"
             xmlns:views="clr-namespace:NCVizDash.TaskPane.Views"
             d:DataContext="{d:DesignInstance vm:CanvasPanelViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="40" />
            <!-- Dashboard info bar (active dashboard name) -->
            <RowDefinition Height="28" />
            <!-- Global filter bar (Phase 9) -->
            <RowDefinition Height="Auto" />
            <!-- Canvas -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,0,0,1"
                Padding="8,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" behaviors:SpacingBehavior.Spacing="2">

                <!-- Undo / Redo (Phase 12) -->
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Undo"
                        Command="{Binding UndoCommand}"
                        IsEnabled="{Binding CanUndo}">
                    <md:PackIcon Kind="Undo" Width="18" Height="18" />
                </Button>
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Redo"
                        Command="{Binding RedoCommand}"
                        IsEnabled="{Binding CanRedo}">
                    <md:PackIcon Kind="Redo" Width="18" Height="18" />
                </Button>

                <Separator Style="{StaticResource MaterialDesignVerticalSeparator}" Margin="6,8" />

                <!-- Duplicate -->
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Duplicate selected widget(s)  Ctrl+D"
                        Command="{Binding DuplicateSelectedWidgetsCommand}">
                    <md:PackIcon Kind="ContentCopy" Width="18" Height="18" />
                </Button>

                <!-- Delete -->
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Delete selected widget(s)  Del"
                        Command="{Binding DeleteSelectedWidgetCommand}">
                    <md:PackIcon Kind="Delete" Width="18" Height="18" />
                </Button>

                <Separator Style="{StaticResource MaterialDesignVerticalSeparator}" Margin="6,8" />

                <!-- Snap to grid toggle -->
                <ToggleButton Style="{StaticResource MaterialDesignIconToggleButton}"
                              ToolTip="Snap to grid"
                              IsChecked="{Binding SnapToGrid, Mode=TwoWay}">
                    <md:PackIcon Kind="MagnetOn" Width="18" Height="18" />
                </ToggleButton>

                <!-- Show grid toggle -->
                <ToggleButton Style="{StaticResource MaterialDesignIconToggleButton}"
                              ToolTip="Show grid"
                              IsChecked="{Binding ShowGrid, Mode=TwoWay}">
                    <md:PackIcon Kind="Grid" Width="18" Height="18" />
                </ToggleButton>

                <Separator Style="{StaticResource MaterialDesignVerticalSeparator}" Margin="6,8" />

                <!-- Clear cross-filters -->
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Clear all cross-filters"
                        Command="{Binding ClearFiltersCommand}">
                    <md:Badged Badge="{Binding ActiveFilterCount}"
                               Visibility="{Binding ActiveFilterCount, Converter={StaticResource CountToVisibilityConverter}}">
                        <md:PackIcon Kind="FilterRemove" Width="18" Height="18" />
                    </md:Badged>
                </Button>

                <Separator Style="{StaticResource MaterialDesignVerticalSeparator}" Margin="6,8" />

                <Button Content="Present"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        FontSize="11"
                        Click="PresentButton_Click">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" behaviors:SpacingBehavior.Spacing="4">
                                <md:PackIcon Kind="Presentation" Width="16" Height="16" />
                                <TextBlock Text="Present" />
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>

                <!-- Selection info -->
                <TextBlock VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Margin="4,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedWidgets.Count}" Value="0">
                                    <Setter Property="Text" Value="Nothing selected" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── Dashboard name bar ── -->
        <Border Grid.Row="1"
                Background="{DynamicResource MaterialDesignBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,0,0,1"
                Padding="12,0">
            <StackPanel Orientation="Horizontal" behaviors:SpacingBehavior.Spacing="8" VerticalAlignment="Center">
                <md:PackIcon Kind="ViewDashboard"
                             Width="14" Height="14"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource PrimaryHueMidBrush}" />
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBody}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="No dashboard open" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveDashboard}" Value="{x:Null}">
                                    <Setter Property="Text" Value="No dashboard open — drag a visual onto the canvas to begin" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding ActiveDashboard.Name}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           Visibility="{Binding ActiveDashboard, Converter={StaticResource NullToCollapsedConverter}}" />
                <TextBlock Text="{Binding Widgets.Count, StringFormat='({0} widget(s))'}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Visibility="{Binding ActiveDashboard, Converter={StaticResource NullToCollapsedConverter}}" />
            </StackPanel>
        </Border>

        <!-- ── Global Filter Bar (Phase 9) ── -->
        <views:GlobalFilterBarView Grid.Row="2"
                                    DataContext="{Binding GlobalFilterBar}" />

        <!-- ── Canvas scroll host ── -->
        <ScrollViewer Grid.Row="3"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#FAFAFA">

            <!-- Minimum canvas size is always at least the scroll-viewer's viewport -->
            <Grid MinWidth="960" MinHeight="640">

                <!-- DashboardCanvas — the custom panel that owns move/resize/select -->
                <ctrl:DashboardCanvas x:Name="TheCanvas"
                                      ViewModel="{Binding}"
                                      ShowGrid="{Binding ShowGrid}"
                                      SnapToGrid="{Binding SnapToGrid}"
                                      RenderCoordinator="{Binding RenderCoordinator}"
                                      FilterManager="{Binding FilterManager}"
                                      GlobalFilterManager="{Binding GlobalFilterManager}"
                                      Theme="{Binding ActiveTheme}"
                                      AllowDrop="True"
                                      DragEnter="Canvas_DragEnter"
                                      DragOver="Canvas_DragOver"
                                      DragLeave="Canvas_DragLeave"
                                      Drop="Canvas_Drop"
                                      KeyDown="Canvas_KeyDown"
                                      Focusable="True" />

                <!-- Empty-state overlay — shown only when there are no widgets -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            behaviors:SpacingBehavior.Spacing="16"
                            IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Widgets.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <md:PackIcon Kind="ChartAreaspline"
                                 Width="72" Height="72"
                                 HorizontalAlignment="Center"
                                 Foreground="#D0D0D0" />
                    <TextBlock Text="Drag a visual from the library"
                               FontSize="15"
                               Foreground="#BDBDBD"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="or drop a field from the Data Explorer"
                               FontSize="12"
                               Foreground="#CCCCCC"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
