<UserControl x:Class="NCVizDash.TaskPane.Views.GlobalFilterBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:NCVizDash.TaskPane.ViewModels"
             xmlns:models="clr-namespace:NCVizDash.Models;assembly=NCVizDash.Models"
             d:DataContext="{d:DesignInstance vm:GlobalFilterBarViewModel}">

    <Border Background="{DynamicResource MaterialDesignBackground}"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="0,0,0,1"
            Padding="10,6">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <md:PackIcon Kind="FilterVariant"
                         Width="16" Height="16"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0"
                         Foreground="{DynamicResource PrimaryHueMidBrush}" />

            <TextBlock Text="Global Filters:"
                       FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Foreground="{DynamicResource MaterialDesignBodyLight}" />

            <!-- Active filter chips -->
            <ItemsControl ItemsSource="{Binding ActiveFilters}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:WidgetFilter}">
                        <md:Chip Content="{Binding FieldName}"
                                 Margin="0,0,6,0"
                                 IsDeletable="True"
                                 DeleteCommand="{Binding DataContext.RemoveFilterCommand,
                                     RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 DeleteCommandParameter="{Binding}"
                                 ToolTip="{Binding Values, Converter={StaticResource FilterValuesToStringConverter}}"
                                 FontSize="11" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add-filter row -->
            <ComboBox ItemsSource="{Binding AvailableFields}"
                      SelectedItem="{Binding SelectedFieldToAdd}"
                      DisplayMemberPath="DisplayLabel"
                      md:HintAssist.Hint="Field"
                      Width="160"
                      FontSize="11"
                      Margin="8,0,4,0"
                      SelectionChanged="FieldCombo_SelectionChanged" />

            <ComboBox ItemsSource="{Binding ValueOptionsForSelectedField}"
                      SelectedItem="{Binding SelectedValueForNewFilter}"
                      md:HintAssist.Hint="Value"
                      Width="140"
                      FontSize="11"
                      Margin="0,0,4,0"
                      IsEnabled="{Binding IsLoadingValues, Converter={StaticResource InverseBooleanConverter}}" />

            <Button Content="Add"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    FontSize="11"
                    Command="{Binding AddSelectedFilterCommand}" />

            <Button Content="Clear All"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    FontSize="11"
                    Margin="8,0,0,0"
                    Command="{Binding ClearAllCommand}"
                    Visibility="{Binding ActiveFilters.Count, Converter={StaticResource CountToVisibilityConverter}}" />

            <ProgressBar IsIndeterminate="True"
                         Width="60" Height="2"
                         Margin="8,0,0,0"
                         Style="{StaticResource MaterialDesignLinearProgressBar}"
                         Visibility="{Binding IsLoadingValues, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>
    </Border>
</UserControl>
