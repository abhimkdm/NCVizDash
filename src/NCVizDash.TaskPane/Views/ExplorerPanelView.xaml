<UserControl x:Class="NCVizDash.TaskPane.Views.ExplorerPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:NCVizDash.TaskPane.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:NCVizDash.TaskPane.ViewModels"
             xmlns:models="clr-namespace:NCVizDash.Models;assembly=NCVizDash.Models"
             d:DataContext="{d:DesignInstance vm:ExplorerPanelViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Panel header -->
            <RowDefinition Height="40" />
            <!-- Search box -->
            <RowDefinition Height="48" />
            <!-- Tree / list -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                Padding="12,0">
            <Grid>
                <TextBlock Text="Data Explorer"
                           FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBody}" />
                <ProgressBar IsIndeterminate="True"
                             Height="2"
                             VerticalAlignment="Bottom"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Border>

        <!-- Search -->
        <TextBox Grid.Row="1"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="8,6"
                 md:HintAssist.Hint="Search tables and fields…"
                 md:TextFieldAssist.HasLeadingIcon="True"
                 md:TextFieldAssist.LeadingIcon="Magnify"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 FontSize="12" />

        <!-- Data source list with field expansion -->
        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredDataSources}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DataSourceDescriptor}">
                            <Expander Margin="4,2"
                                      IsExpanded="True"
                                      MouseEnter="DataSourceHeader_MouseEnter"
                                      MouseLeave="DataSourceHeader_MouseLeave">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal" behaviors:SpacingBehavior.Spacing="6">
                                        <md:PackIcon Kind="Table"
                                                     Width="16" Height="16"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{Binding SourceType}" />
                                        <TextBlock Text="{Binding RowCount, StringFormat='({0:N0} rows)'}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Expander.Header>

                                <!-- Field list -->
                                <ItemsControl ItemsSource="{Binding Fields}"
                                              Margin="16,0,0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:FieldDescriptor}">
                                            <Border Padding="4,3"
                                                    CornerRadius="4"
                                                    Cursor="Hand"
                                                    Background="Transparent"
                                                    PreviewMouseLeftButtonDown="FieldRow_PreviewMouseLeftButtonDown"
                                                    MouseMove="FieldRow_MouseMove">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background"
                                                                        Value="{DynamicResource MaterialDesignSelection}" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal" behaviors:SpacingBehavior.Spacing="6">
                                                    <!-- Drag handle affordance -->
                                                    <md:PackIcon Kind="DragVertical"
                                                                 Width="12" Height="12"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource MaterialDesignBodyLight}" />

                                                    <!-- Field type icon -->
                                                    <md:PackIcon Width="14" Height="14"
                                                                 VerticalAlignment="Center">
                                                        <md:PackIcon.Style>
                                                            <Style TargetType="md:PackIcon">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding FieldType}" Value="Measure">
                                                                        <Setter Property="Kind" Value="Numeric" />
                                                                        <Setter Property="Foreground" Value="#2196F3" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FieldType}" Value="Dimension">
                                                                        <Setter Property="Kind" Value="FormatText" />
                                                                        <Setter Property="Foreground" Value="#4CAF50" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FieldType}" Value="Time">
                                                                        <Setter Property="Kind" Value="Calendar" />
                                                                        <Setter Property="Foreground" Value="#FF9800" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding FieldType}" Value="Filter">
                                                                        <Setter Property="Kind" Value="Filter" />
                                                                        <Setter Property="Foreground" Value="#9C27B0" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </md:PackIcon.Style>
                                                    </md:PackIcon>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               ToolTip="{Binding FieldType}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty / no-results state -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        behaviors:SpacingBehavior.Spacing="8">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FilteredDataSources.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <md:PackIcon Kind="DatabaseSearch"
                             Width="40" Height="40"
                             HorizontalAlignment="Center"
                             Foreground="#BDBDBD" />
                <TextBlock Text="No data sources found"
                           FontSize="12"
                           Foreground="#BDBDBD"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Hover preview popup: small data grid showing sample rows -->
        <Popup x:Name="PreviewPopup"
               Placement="Right"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="{DynamicResource MaterialDesignPaper}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8"
                    MaxWidth="420"
                    MaxHeight="300">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.3" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding PreviewSource.Name, StringFormat='Preview: {0}'}"
                               FontWeight="SemiBold"
                               FontSize="11"
                               Margin="0,0,0,4" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding PreviewRows}"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              FontSize="10"
                              RowHeight="22" />
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
