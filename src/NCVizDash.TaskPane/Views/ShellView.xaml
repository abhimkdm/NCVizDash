<UserControl x:Class="NCVizDash.TaskPane.Views.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:NCVizDash.TaskPane.Behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:NCVizDash.TaskPane.ViewModels"
        xmlns:views="clr-namespace:NCVizDash.TaskPane.Views"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignBackground}"
        FontFamily="{md:MaterialDesignFont}"
        d:DataContext="{d:DesignInstance vm:ShellViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ExplorerColumn" MinWidth="0" MaxWidth="400">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="280" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ExplorerPanel.IsCollapsed}" Value="True">
                                    <Setter Property="Width" Value="36" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="220" MinWidth="190" MaxWidth="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,1,0">
                <ContentControl Content="{Binding ExplorerPanel}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:ExplorerPanelView x:Name="ExplorerView" DataContext="{Binding}" />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource MaterialDesignDivider}" />

            <Border Grid.Column="2"
                    Background="{DynamicResource MaterialDesignBackground}">
                <Grid>
                    <ContentControl Content="{Binding CanvasPanel}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:CanvasPanelView DataContext="{Binding}" />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <!-- Empty state — shown when no dashboard is open yet, so this
                         area reads as "nothing here yet" rather than looking broken. -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                behaviors:SpacingBehavior.Spacing="8"
                                Visibility="{Binding CanvasPanel.ActiveDashboard, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter=Invert}">
                        <md:PackIcon Kind="ViewDashboardOutline" Width="48" Height="48"
                                     HorizontalAlignment="Center" Foreground="#BDBDBD" />
                        <TextBlock Text="No dashboard open"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#9E9E9E" HorizontalAlignment="Center" />
                        <TextBlock Text="Click Generate Dashboard or a Template to get started"
                                   FontSize="12" Foreground="#BDBDBD" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource MaterialDesignDivider}" />

            <Border Grid.Column="4"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1,0,0,0">
                <ContentControl Content="{Binding VisualLibrary}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:VisualLibraryView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
        </Border>

        <!-- Full-pane loading overlay (refresh / generate dashboard) -->
        <Border Grid.RowSpan="2"
                Background="#AAFAFAFA"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        behaviors:SpacingBehavior.Spacing="16">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             Value="0"
                             IsIndeterminate="True"
                             Width="52"
                             Height="52" />
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           MaxWidth="360"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
