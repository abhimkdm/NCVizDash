<UserControl x:Class="NCVizDash.TaskPane.Views.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:NCVizDash.TaskPane.Behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:NCVizDash.TaskPane.ViewModels"
        xmlns:views="clr-namespace:NCVizDash.TaskPane.Views"
        mc:Ignorable="d"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignBackground}"
        FontFamily="{md:MaterialDesignFont}"
        d:DataContext="{d:DesignInstance vm:ShellViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueMidBrush}"
                Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" behaviors:SpacingBehavior.Spacing="10">
                    <md:PackIcon Kind="ChartAreaspline"
                                 Width="28" Height="28"
                                 Foreground="White"
                                 VerticalAlignment="Center" />
                    <TextBlock Text="NC VizDash"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center" />
                </StackPanel>

                <ProgressBar Grid.Column="1"
                             IsIndeterminate="{Binding IsLoading}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"
                             VerticalAlignment="Bottom"
                             Margin="24,0" />

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" behaviors:SpacingBehavior.Spacing="8">
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            ToolTip="Pop out dashboard into its own window"
                            Command="{Binding RequestPopOutCommand}"
                            Foreground="White"
                            Padding="4">
                        <md:PackIcon Kind="OpenInNew" Width="20" Height="20" />
                    </Button>

                    <TextBlock Text="Dark"
                               Foreground="White"
                               VerticalAlignment="Center"
                               FontSize="12" />
                    <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  ToolTip="Toggle Light / Dark theme"
                                  Command="{Binding ApplyThemeCommand}"
                                  CommandParameter="Dark" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="220" MinWidth="190" MaxWidth="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="0,0,1,0">
                <ContentControl Content="{Binding ExplorerPanel}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:ExplorerPanelView DataContext="{Binding}" />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource MaterialDesignDivider}" />

            <Border Grid.Column="2"
                    Background="{DynamicResource MaterialDesignBackground}">
                <ContentControl Content="{Binding CanvasPanel}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:CanvasPanelView DataContext="{Binding}" />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>

            <GridSplitter Grid.Column="3"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource MaterialDesignDivider}" />

            <Border Grid.Column="4"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1,0,0,0">
                <ContentControl Content="{Binding VisualLibrary}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:VisualLibraryView />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
        </Border>

        <!-- Full-pane loading overlay (refresh / generate dashboard) -->
        <Border Grid.RowSpan="3"
                Background="#AAFAFAFA"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        behaviors:SpacingBehavior.Spacing="16">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             Value="0"
                             IsIndeterminate="True"
                             Width="52"
                             Height="52" />
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           MaxWidth="360"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
