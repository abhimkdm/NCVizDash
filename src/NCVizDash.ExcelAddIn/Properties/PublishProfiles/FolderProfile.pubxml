<?xml version="1.0" encoding="utf-8"?>
<!--
  VSTO folder publish profile.
  In Visual Studio: right-click NCVizDash.ExcelAddIn → Publish → pick this profile.
  From command line: scripts\Publish-ExcelAddIn.ps1
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>..\..\publish\</PublishDir>
    <PublishUrl>..\..\publish\</PublishUrl>
    <InstallUrl />
    <TargetCulture>en</TargetCulture>
    <ApplicationVersion>1.0.0.0</ApplicationVersion>
    <UpdateEnabled>false</UpdateEnabled>
    <MapFileExtensions>true</MapFileExtensions>
    <IsWebBootstrapper>false</IsWebBootstrapper>
    <BootstrapperEnabled>true</BootstrapperEnabled>
    <BootstrapperComponentsLocation>HomeSite</BootstrapperComponentsLocation>
    <GenerateManifests>true</GenerateManifests>
    <!-- Requires a test certificate: project Properties → Signing → Create Test Certificate -->
    <SignManifests>true</SignManifests>
    <PublishWizardCompleted>true</PublishWizardCompleted>
  </PropertyGroup>
</Project>
